generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
}

enum ProjectStatus {
  PLANNED
  ACTIVE
  ON_HOLD
  COMPLETED
}

enum TaskStatus {
  TODO
  IN_PROGRESS
  DONE
}

enum TaskPriority {
  LOW
  MEDIUM
  HIGH
}

enum InvoiceStatus {
  UNPAID
  PAID
}

model User {
  id        String   @id @default(cuid())
  name      String
  email     String   @unique
  password  String
  role      Role     @default(ADMIN)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  clients     Client[]
  projects    Project[]
  invoices    Invoice[]
  attachments Attachment[]
}

model Client {
  id        String   @id @default(cuid())
  userId    String
  name      String
  email     String?
  phone     String?
  company   String?
  notes     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  projects Project[]
  invoices Invoice[]

  @@index([userId])
}

model Project {
  id          String        @id @default(cuid())
  userId      String
  clientId    String
  title       String
  description String?
  status      ProjectStatus @default(PLANNED)
  budget      Decimal?      @db.Decimal(12, 2)
  deadline    DateTime?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  user        User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  client      Client       @relation(fields: [clientId], references: [id], onDelete: Cascade)
  tasks       Task[]
  invoices    Invoice[]
  attachments Attachment[]

  @@index([userId])
  @@index([clientId])
}

model Task {
  id        String       @id @default(cuid())
  projectId String
  title     String
  status    TaskStatus   @default(TODO)
  priority  TaskPriority @default(MEDIUM)
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
}

model Invoice {
  id        String        @id @default(cuid())
  userId    String
  clientId  String
  projectId String?
  amount    Decimal       @db.Decimal(12, 2)
  status    InvoiceStatus @default(UNPAID)
  notes     String?
  dueDate   DateTime?
  paidAt    DateTime?
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt

  user        User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  client      Client       @relation(fields: [clientId], references: [id], onDelete: Cascade)
  project     Project?     @relation(fields: [projectId], references: [id], onDelete: SetNull)
  attachments Attachment[]

  @@index([userId])
  @@index([clientId])
  @@index([projectId])
}

model Attachment {
  id        String   @id @default(cuid())
  userId    String
  projectId String?
  invoiceId String?
  name      String
  mimeType  String
  size      Int      @default(0)
  url       String? // external link (e.g. Google Drive)
  data      Bytes? // small uploaded files stored inline
  createdAt DateTime @default(now())

  user    User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  project Project? @relation(fields: [projectId], references: [id], onDelete: Cascade)
  invoice Invoice? @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([projectId])
  @@index([invoiceId])
}
